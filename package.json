{
  "name": "kobina-pro",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @kobina/web dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @kobina/db db:generate",
    "db:migrate": "pnpm --filter @kobina/db db:migrate",
    "mobile:sync": "pnpm --filter @kobina/mobile cap:sync"
  }
}
