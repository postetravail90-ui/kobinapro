# Copier vers .env (ne pas commiter .env). Valeurs ci-dessous = placeholders.

VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
# Alias possible :
# VITE_SUPABASE_ANON_KEY=

# Edge Function sync (kobina-pro) — JWT utilisateur
VITE_SYNC_BATCH_ENDPOINT=https://YOUR-PROJECT.supabase.co/functions/v1/sync-batch

# Firebase (web push / messagerie)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
