{
  "name": "@kobina/mobile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "cap:sync": "pnpm exec cap sync",
    "cap:open:android": "pnpm exec cap open android",
    "build:web": "pnpm --filter @kobina/web build",
    "prepare:native": "pnpm run build:web && pnpm exec cap sync android"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^6.0.2",
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.2.1",
    "@capacitor/network": "^6.0.4",
    "capacitor-secure-storage-plugin": "0.10.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "typescript": "~5.8.3"
  }
}
